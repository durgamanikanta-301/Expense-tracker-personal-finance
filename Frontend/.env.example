# -------------------------------------------------------
# FinFlow Frontend - Environment Variables
# -------------------------------------------------------
# For LOCAL development: No .env file needed!
# The Vite proxy in vite.config.js automatically routes
# all /api calls to http://localhost:8080.
#
# For PRODUCTION (Vercel): Create a .env file with:
# -------------------------------------------------------

# The full URL to your deployed Render backend.
# DO NOT add a trailing slash.
VITE_API_BASE_URL=https://your-backend-app.onrender.com/api
